# Dockerfile.agent — Container for running the autonomous issue-daemon agent.
#
# Installs Node.js 22, git, Claude CLI, gh CLI, and jq.
# The repo is mounted read-only at /workspace. The entrypoint script clones
# it into a writable location (/agent-workdir/repo) for git worktree support.
# Secrets are passed via environment variables — NEVER baked into the image.
#
# Build:
#   docker build -f Dockerfile.agent -t ai-social-agent .
#
# Run:
#   See docker-compose.agent.yml for the recommended way to run.

FROM node:22-bookworm-slim

LABEL maintainer="ai-social team"
LABEL description="Autonomous agent worker for ai-social issue daemon"

ARG DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    jq \
    curl \
    ca-certificates \
    gnupg \
    tmux \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI (gh)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Install Claude CLI via npm (global)
# Pin to explicit version for supply-chain safety. Update intentionally.
ARG CLAUDE_CLI_VERSION=latest
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CLI_VERSION}

# Create a non-root user for running the agent
RUN groupadd --gid 1000 agent \
    && useradd --uid 1000 --gid agent --shell /bin/bash --create-home agent

# Create directories for worktrees and logs
RUN mkdir -p /workspace /agent-workdir/repo /agent-workdir/logs \
    && chown -R agent:agent /agent-workdir

# Copy scripts into the image (entrypoint, healthcheck, status server)
COPY --chown=agent:agent scripts/agent-entrypoint.sh /usr/local/bin/agent-entrypoint
COPY --chown=agent:agent scripts/agent-healthcheck.sh /usr/local/bin/agent-healthcheck
COPY --chown=agent:agent scripts/agent-status-server.js /usr/local/bin/agent-status-server.js
RUN chmod +x /usr/local/bin/agent-entrypoint /usr/local/bin/agent-healthcheck

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD /usr/local/bin/agent-healthcheck

# Expose the status server port
EXPOSE 7420

# Switch to non-root user
USER agent

WORKDIR /workspace

# Entrypoint handles repo clone, git config, status server, then execs daemon
ENTRYPOINT ["agent-entrypoint"]

# Default daemon args (can be overridden at runtime)
CMD ["-w", "1", "-i", "60"]
