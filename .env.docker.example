# .env.docker — Credentials for the agent Docker container.
#
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# IMPORTANT: .env.docker is gitignored and must NEVER be committed.
# All values here are passed as runtime environment variables — they are
# never baked into the Docker image.

# --- Required -----------------------------------------------------------------

# Anthropic API key for Claude Code CLI.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GitHub personal access token with 'repo' scope.
# The daemon uses this for: reading/writing issues, creating PRs, pushing code.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Optional -----------------------------------------------------------------

# Database connection string (only needed if workers run DB-dependent tests).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Agent Configuration (all have sensible defaults) -------------------------

# Max parallel workers (default: 1). Start low, increase after validation.
# AGENT_MAX_WORKERS=1

# Poll interval in seconds (default: 60). How often to check for new issues.
# AGENT_POLL_INTERVAL=60

# Max budget per issue in USD (default: 50). Workers stop after exceeding this.
# AGENT_MAX_BUDGET=50

# --- Resource Limits (can also be set in docker-compose.agent.yml) -----------

# CPU cores limit (default: 2.0)
# AGENT_CPU_LIMIT=2.0

# Memory limit (default: 4G)
# AGENT_MEMORY_LIMIT=4G

# --- Status Server ------------------------------------------------------------

# Port for the HTTP status endpoint (default: 7420)
# AGENT_STATUS_PORT=7420

# --- Claude CLI Auth ----------------------------------------------------------

# Path to your Claude CLI config directory (default: ~/.claude).
# The directory is mounted read-only into the container.
# CLAUDE_CONFIG_DIR=~/.claude
