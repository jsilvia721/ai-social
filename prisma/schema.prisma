generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth models ───────────────────────────────────────────────────────────

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  isAdmin          Boolean          @default(false) // global admin — bypasses workspace membership checks
  activeBusinessId String?          // denormalized JWT cache — validated on session hydration
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  accounts         Account[]
  sessions         Session[]
  businesses       BusinessMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Business workspace models ─────────────────────────────────────────────────

model Business {
  id                String            @id @default(cuid())
  name              String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  members           BusinessMember[]
  socialAccounts    SocialAccount[]
  posts             Post[]
  contentStrategy   ContentStrategy?
  researchSummaries ResearchSummary[]
  contentBriefs     ContentBrief[]
  strategyDigests   StrategyDigest[]
}

model BusinessMember {
  id         String       @id @default(cuid())
  businessId String
  userId     String
  role       BusinessRole @default(MEMBER)
  joinedAt   DateTime     @default(now())
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
}

model ContentStrategy {
  id                  String   @id @default(cuid())
  businessId          String   @unique
  industry            String
  targetAudience      String
  contentPillars      String[]
  brandVoice          String   @db.Text
  optimizationGoal    String
  reviewWindowEnabled Boolean  @default(false)
  reviewWindowHours   Int      @default(24)
  postingCadence      Json?    // e.g., { "TWITTER": 5, "INSTAGRAM": 3 } — posts per platform per week
  researchSources     Json?    // e.g., { rssFeeds: ["https://..."], subreddits: ["r/..."] }
  formatMix           Json?    // e.g., { "TEXT": 0.2, "IMAGE": 0.3, "VIDEO": 0.5 } — target format distribution
  optimalTimeWindows  Json?    // e.g., { "TWITTER": ["09:00-11:00", "17:00-19:00"] }
  accountType         String   @default("BUSINESS") // BUSINESS | INFLUENCER | MEME
  visualStyle         String?  @db.Text             // "clean minimalist", "chaotic meme energy"
  lastOptimizedAt     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ── Social accounts & posts ───────────────────────────────────────────────────

model SocialAccount {
  id               String    @id @default(cuid())
  businessId       String
  platform         Platform
  platformId       String
  username         String
  blotatoAccountId String    @unique
  // Release 3: drop these columns once all code fully uses blotatoAccountId
  accessToken      String?   @db.Text
  refreshToken     String?   @db.Text
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  business         Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  posts            Post[]

  @@unique([platform, platformId])
  @@index([businessId])
}

model Post {
  id                    String        @id @default(cuid())
  businessId            String
  socialAccountId       String
  content               String        @db.Text
  mediaUrls             String[]
  coverImageUrl         String?
  status                PostStatus    @default(DRAFT)
  retryCount            Int           @default(0)
  retryAt               DateTime?
  scheduledAt           DateTime?
  publishedAt           DateTime?
  reviewWindowExpiresAt DateTime?
  blotatoPostId         String?
  errorMessage          String?
  briefId               String?       @unique
  repurposeGroupId      String?   // cuid linking variant posts from a single repurpose operation
  topicPillar           String?   // which content pillar this maps to
  tone                  String?   // "educational" | "entertaining" | "promotional" | "community"
  metricsLikes          Int?
  metricsComments       Int?
  metricsShares         Int?
  metricsImpressions    Int?
  metricsReach          Int?
  metricsSaves          Int?
  metricsUpdatedAt      DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  business              Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  socialAccount         SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  contentBrief          ContentBrief?

  @@index([status, scheduledAt])
  @@index([status, retryAt])
  @@index([status, metricsUpdatedAt])
  @@index([status, reviewWindowExpiresAt])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, publishedAt])
  @@index([repurposeGroupId])
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Platform {
  TWITTER
  INSTAGRAM
  FACEBOOK
  TIKTOK
  YOUTUBE
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  PENDING_REVIEW
  RETRYING
  PUBLISHING
}

enum BusinessRole {
  OWNER
  MEMBER
}

// ── Content Intelligence (M2) ────────────────────────────────────────────────

model ResearchSummary {
  id                String   @id @default(cuid())
  businessId        String
  sourceItems       Json     // raw items from Google Trends, RSS, Reddit
  synthesizedThemes String   @db.Text // Claude's thematic synthesis
  sourcesUsed       String[] // ["google_trends", "rss", "reddit"]
  createdAt         DateTime @default(now())
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
}

model ContentBrief {
  id                String      @id @default(cuid())
  businessId        String
  researchSummaryId String?
  topic             String
  rationale         String      @db.Text
  suggestedCaption  String      @db.Text
  aiImagePrompt     String?     @db.Text
  contentGuidance   String?     @db.Text
  recommendedFormat BriefFormat
  platform          Platform
  scheduledFor      DateTime
  status            BriefStatus @default(PENDING)
  weekOf            DateTime
  sortOrder         Int         @default(0)
  retryCount        Int         @default(0)
  errorMessage      String?     @db.Text
  postId            String?     @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  post              Post?       @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([businessId, scheduledFor])
  @@index([status, weekOf])
  @@index([status, scheduledFor])
}

enum BriefFormat {
  TEXT
  IMAGE
  CAROUSEL
  VIDEO
}

enum BriefStatus {
  PENDING
  FULFILLING
  FULFILLED
  FAILED
  EXPIRED
  CANCELLED
}

// ── Strategy Optimizer (M3) ─────────────────────────────────────────────────

model StrategyDigest {
  id         String   @id @default(cuid())
  businessId String
  weekOf     DateTime
  summary    String   @db.Text // plain-language digest for partner
  patterns   Json     // { topPerformers: [...], insights: [...] }
  changes    Json     // { formatMix: {...}, cadence: {...}, ... }
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, weekOf])
  @@index([businessId, createdAt])
}

// ── Error Tracking ──────────────────────────────────────────────────────────

model ErrorReport {
  id                String   @id @default(cuid())
  fingerprint       String   @unique          // SHA-256 hash of normalized error message + source
  message           String                     // Error message
  stack             String?  @db.Text          // Stack trace if available
  source            String                     // "SERVER" or "CLIENT"
  url               String?                    // URL where error occurred (page or API route)
  metadata          Json?                      // Additional context (user agent, request info, etc.)
  count             Int      @default(1)       // How many times this error has been seen
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  status            String   @default("NEW")   // NEW, ISSUE_CREATED, RESOLVED, IGNORED
  githubIssueNumber Int?                        // Linked GitHub issue number
  acknowledgedAt    DateTime?                    // When bug monitor last triaged this error
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, lastSeenAt])
  @@index([source, status])
}
